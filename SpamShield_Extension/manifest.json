{
  "manifest_version": 3,
  "name": "SpamShield",
  "version": "1.0",
  "description": "Spam Detection Extension",
  "permissions": ["activeTab", "scripting"],
  "host_permissions": [
    "http://localhost:5000/*",
    "http://127.0.0.1:5000/*",
    "https://mail.google.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://mail.google.com/*"],
      "js": ["content.js"],
      "css": ["style.css"]
    }
  ]
}